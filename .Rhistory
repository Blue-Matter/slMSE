myMSE = Project(hist, "Eff")                     # Projection - current effort
Eff = function(Data, rel_TAE = 1){
season = get_season(Data)                                          # Get season (this time step, not last with data) [14]
ad = new('advice')                                                 # Make new Advice object
ad = do_TAE(Data, rel_TAE, season, ad)
ad
}
class(Eff) = "mp"
do_TAE = function(Data, rel_TAE, season, ad, nyrs=3, ns=4){
ad@EffType = 'Abs'
if(!is.na(TAE[1])){  # Absolute effort (can be total, by fleet, by fleet x area)
ad@Effort = TAE
}
if(!is.na(rel_TAE[1])) {
takets = match(Data@YearLH, Data@Years) - (nyrs * ns -1):0
Effort = Data@Misc$DataOM@Effort[1,takets,]
nf = dim(Effort)[2]
muEffort = apply(array(Effort,c(ns,nyrs,nf)),c(1,3),mean)
histEff = muEffort[season,]
newEffort <- histEff*rel_TAE
Dist = Data@Misc$DataOM@Distribution[1,takets,,]
nr = dim(Dist)[3]
muDist = apply(array(Dist,c(ns,nyrs,nf,nr)),c(1,3,4),mean)
EffortFleetArea <- newEffort * muDist[season,,]
ad@Effort = EffortFleetArea
}
ad
}
get_season = function(Data){
rep(1:4,1000)[max(Data@Years)-Data@YearLH+1] # This is the season following the data of this season - so one time step ahead and the correct index for TAC and Effort distribution
}
